# Primary production market-data source. Keep this key server-side only.
MARKET_DATA_PROVIDER="tt_bridge"
TT_BRIDGE_API_KEY=""
TT_BRIDGE_BASE_URL="https://tt-bridge.rfdelta.com"
TT_BRIDGE_EXPIRATION_LIMIT="10"
TT_BRIDGE_STRIKE_COUNT="24"
TT_BRIDGE_CHAIN_CONCURRENCY="4"
TT_BRIDGE_QUOTE_BATCH_SIZE="25"
TT_BRIDGE_QUOTE_BATCH_CONCURRENCY="2"

# Public finalized daily bars used to hydrate technical indicators.
PUBLIC_HISTORY_ENABLED="true"
PUBLIC_HISTORY_LOOKBACK_DAYS="400"
PUBLIC_HISTORY_MAX_BARS="260"
PUBLIC_HISTORY_CONCURRENCY="4"

# Recent public market headlines used by the deterministic Daily Market Read.
MARKET_NEWS_ENABLED="true"
MARKET_NEWS_MAX_ITEMS="6"

# Optional Tradier adapter. It remains available only when explicitly selected.
TRADIER_ACCESS_TOKEN=""
TRADIER_BASE_URL="https://api.tradier.com/v1"
MARKET_DATA_PUBLICATION_LICENSE_ACKNOWLEDGED="false"

# Optional generation controls.
# Leave empty to use the categorized default quote universe in lib/market/universe.ts.
OPTIONS_UNIVERSE=""
OPTIONS_CHAIN_SYMBOL_LIMIT="40"
OPTIONS_CORE_SYMBOLS="SPY,QQQ,IWM,DIA,TLT,GLD,XLE,XLK,SMH"
OPTIONS_MOVER_SLOTS="18"
OPTIONS_VOLUME_SLOTS="7"
REPORT_TIME_ZONE="America/New_York"
REPORT_MIN_DTE="7"
REPORT_MAX_DTE="35"
REPORT_TARGET_DTE="14"
REPORT_MIN_OPTION_VOLUME="25"
REPORT_MIN_OPEN_INTEREST="100"
REPORT_MAX_BID_ASK_WIDTH_PCT="30"
REPORT_REQUIRE_SAME_SESSION_QUOTES="true"

# Deterministic model controls.
PUBLISH_IDEA_COUNT="5"
PUBLISH_FORCE_MIN_CREDIT_SPREADS="1"
PUBLISH_FORCE_MIN_DEBIT_SPREADS="2"
PUBLISH_MAX_SINGLE_TRADE_RISK_DOLLARS="250"
PUBLISH_MAX_TOTAL_BASKET_RISK_DOLLARS="800"
MODEL_PATHS_PER_CANDIDATE="100000"
MODEL_DEFAULT_RISK_FREE_RATE="0.045"
MODEL_DETERMINISTIC_SEED="6192026"
MODEL_MIN_CREDIT_RECEIVED_WIDTH_PCT="0.20"
MODEL_MIN_PROFIT_PROBABILITY_CREDIT="0.52"
MODEL_MIN_PROFIT_PROBABILITY_DEBIT="0.25"
MODEL_REGIME_SHOCK_WEIGHT="0.35"
MODEL_JUMP_SHOCK_PROBABILITY="0.06"
MODEL_MIN_PUBLICATION_SCORE="70"
MODEL_MIN_PROBABILITY_MARGIN="0.05"
MODEL_MIN_POSITIVE_MODELS="3"
MODEL_MIN_CONSERVATIVE_EV_DOLLARS="0"
MODEL_MIN_LIQUIDITY_SCORE="0.80"
MODEL_MIN_MULTI_HORIZON_ALIGNMENT="0.50"
MODEL_MIN_SESSION_CONFIRMATION_MOVE_PCT="0.0015"
MODEL_REQUIRE_COMPLETE_LEG_DATA="true"
MODEL_REQUIRE_SESSION_CONFIRMATION="true"

# Deterministic outcome-trained feature policy.
TRAINING_MIN_RESOLVED_TRADES="8"
TRAINING_RIDGE_REGULARIZATION="2"
TRAINING_MAX_SCORE_ADJUSTMENT="8"

# Used only by the GitHub publication verification step.
PRODUCTION_URL="https://rfdelta-daily-top-option-trades.vercel.app"
VERCEL_DEPLOY_HOOK_URL=""
